{
  "analysis": {
    "normalizer": {
      "sort_normalizer": {
        "type": "custom",
        "filter": [
          "lowercase",
          "asciifolding"
        ]
      }
    },
    "analyzer": {
      "ngram_analyzer": {
        "type": "custom",
        "tokenizer": "edge_ngram_tokenizer",
        "filter": [
          "lowercase",
          "asciifolding"
        ]
      }
    },
    "tokenizer": {
      "edge_ngram_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 3,
        "max_gram": 6,
        "token_chars": [
          "letter",
          "digit"
        ]
      }
    }
  }
}